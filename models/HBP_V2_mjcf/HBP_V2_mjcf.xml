<mujoco model="HBP_V2_mjcf">
  <compiler angle="radian" meshdir="assets" autolimits="true" />

  <option timestep="0.001" iterations="30" cone="elliptic" impratio="100" gravity="0 0 -9.81"/>

  <default>
    <!-- textset -->
    <!-- <joint damping="0.1" armature="0.01" frictionloss="0.005"/> -->
    <position inheritrange="1" timeconst="0.01"/>
    <!-- <geom friction="0.4" margin="0.001" condim="3"/> -->
    <!-- text�[text�Fgroup=0 -->
    <default class="collision">
      <geom group="0"/>
    </default>
    <!-- text�Fgroup=1(text) -->
    <default class="visual">
      <geom contype="0" conaffinity="0" group="1"/>
    </default>
  </default>

  <asset>
    <material name="metal" rgba=".9 .95 .95 1" />
    <material name="black" rgba="0 0 0 1" />
    <material name="white" rgba="1 1 1 1" />
    <material name="gray" rgba="0.671705 0.692426 0.774270 1" />

    <mesh name="back_tire" file="back_tire.obj" />
    <mesh name="body" file="body.obj" />
    <mesh name="flont_tire_holder" file="flont_tire_holder.obj" />
    <mesh name="front_tire" file="front_tire.obj" />
  </asset>

  <worldbody>
    <body name="body_obj" pos="0 0 0.111">
      <freejoint />
      <!-- <joint type="slide" axis="1 0 0" pos="0 0 0" name="root_x"/>
      <joint type="slide" axis="0 1 0" pos="0 0 0" name="root_y"/>
      <joint type="slide" axis="0 0 1" pos="0 0 0" name="root_z"/>
      <joint type="hinge" axis="0 1 0" pos="0 0 0" name="root_y_arg"/>
      <joint type="hinge" axis="0 0 1" pos="0 0 0" name="root_z_arg"/>
      <joint type="hinge" axis="1 0 0" pos="0 0 0" name="root_x_arg"/> -->
      <!-- <geom class="visual" type="mesh" mesh="body" rgba="1.0 1.0 1.0 1.0"/> -->
      <geom type="mesh" mesh="body" group="0" />
      <geom type="mesh" mesh="body" group="0" contype="0" conaffinity="0"/>
      <inertial pos="-0.015137 0 0.12311" mass="0.283" diaginertia="1.576e-4 4.417e-4 4.276e-4" />
      <site name="imu_site" pos="0 0 0.003" size="0.005"/>


      <!-- back_tire -->
      <body name="back_tire" pos="0.098484 0.0 -0.075">
        <!-- <joint name="back_tire_pitch" type="hinge" pos="0 0 0" axis="0 1 0" limited="false" damping="0.00001" armature="0.000025"/> -->
        <joint name="back_tire_pitch" type="hinge" pos="0 0 0" axis="0 1 0" limited="false" damping="0.00001" />
        <inertial pos="-0 -0.001407 -0" mass="0.034" diaginertia="9.523809e-6 1.6211526e-5 9.52381e-6" />
        <geom class="visual" type="mesh" mesh="back_tire"/>
        <geom type="mesh" mesh="back_tire" group="0" friction="0.9 0.05 0.01" />
        <!-- <geom type="mesh" mesh="back_tire" contype="0" conaffinity="0" /> -->
        <geom class="visual" type="box" size="0.005 0.015 0.002" pos="0.02 -0.002 0" rgba="1 0 0 1"/>
      </body>

      <!-- front_tire_holder -->
      <body name="front_tire_holder" pos="-0.062 0.0 -0.03">
        <joint name="tire_holder_yaw" type="hinge" pos="0 0 0" axis="0 0 1" range="-3.14159 3.14159" 
          limited="true"  armature="0.00001" damping="0.00001" />
        <inertial pos="0 0 -0.013803" mass="0.009" diaginertia="2.787516e-6 2.462803e-6 1.235669e-6" />
        <geom class="visual" type="mesh" mesh="flont_tire_holder" rgba="1.0 1.0 1.0 1.0" />
        <geom type="mesh" mesh="flont_tire_holder" group="0" />

        <!-- front_tire -->
        <body name="front_tire" pos="0.0 0.0 -0.042">
          <!-- <joint name="front_tire_pitch" type="hinge" pos="0 0 0" axis="0 1 0" limited="false" damping="0.00001" armature="0.000025"/> -->
          <joint name="front_tire_pitch" type="hinge" pos="0 0 0" axis="0 1 0" limited="false" damping="0.00001" />
          <inertial pos="-0 -0 -0" mass="0.026" diaginertia="7.810778e-6 1.5042828e-5 7.810779e-6" />
          <geom class="visual" type="mesh" mesh="front_tire" rgba="1.0 1.0 1.0 1.0"/>
          <geom type="mesh" mesh="front_tire" group="0" friction="0.9 0.05 0.01" />
          <!-- <geom type="mesh" mesh="front_tire" contype="0" conaffinity="0" /> -->
          <geom class="visual" type="box" size="0.005 0.005 0.002" pos="0.02 -0.002 0" rgba="1 0 0 1"/>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <position name="fork_controler" joint="tire_holder_yaw" gear="1" 
          kp="100" kv="1" forcerange="-0.021 0.021" forcelimited="true"/>
    <!-- <motor name="back_tire_motor" joint="back_tire_pitch" gear="2"/> -->
    <general name="back_tire_motor" joint="back_tire_pitch" 
                dyntype="filter" dynprm="0.0055"
                gaintype="fixed" gainprm="2" 
                biastype="affine" biasprm="0 0 -0.000333"/>
  </actuator>

  <contact>
    <exclude body1="body_obj" body2="back_tire" />
    <exclude body1="body_obj" body2="front_tire" />
    <exclude body1="body_obj" body2="front_tire_holder" />
    <exclude body1="front_tire_holder" body2="front_tire" />
  </contact>

  <sensor>
    <accelerometer name="body_accel" site="imu_site"/>
    <gyro name="body_gyro" site="imu_site" />  
  </sensor>
</mujoco>
