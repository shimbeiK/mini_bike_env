<mujoco model="HBP_V2_mjcf">
  <compiler angle="radian" meshdir="assets" autolimits="true" />

  <option timestep="0.001" iterations="30" cone="elliptic" gravity="0 0 -9.81"/>

  <default>
    <!-- textset -->
    <!-- <joint damping="0.1" armature="0.01" frictionloss="0.005"/> -->
    <position inheritrange="1" timeconst="0.01"/>
    <!-- <geom friction="0.4" margin="0.001" condim="3"/> -->
    <!-- text�[text�Fgroup=0 -->
    <default class="collision">
      <geom group="0"/>
    </default>
    <!-- text�Fgroup=1(text) -->
    <default class="visual">
      <geom contype="0" conaffinity="0" group="1"/>
    </default>
  </default>

  <asset>
    <material name="metal" rgba=".9 .95 .95 1" />
    <material name="black" rgba="0 0 0 1" />
    <material name="white" rgba="1 1 1 1" />
    <material name="gray" rgba="0.671705 0.692426 0.774270 1" />

    <mesh name="back_tire" file="back_tire.obj" />
    <mesh name="body" file="body.obj" />
    <mesh name="front_tire_holder" file="front_tire_holder.obj" />
    <mesh name="front_tire" file="front_tire.obj" />
  </asset>

  <worldbody>
    <body name="body_obj" pos="0.0 0.0 0.110">
      <freejoint />
      <!-- <joint type="slide" axis="1 0 0" pos="0 0 0" name="root_x"/>
      <joint type="slide" axis="0 1 0" pos="0 0 0" name="root_y"/>
      <joint type="slide" axis="0 0 1" pos="0 0 0" name="root_z"/>
      <joint type="hinge" axis="0 1 0" pos="0 0 0" name="root_y_arg"/>
      <joint type="hinge" axis="0 0 1" pos="0 0 0" name="root_z_arg"/>
      <joint type="hinge" axis="1 0 0" pos="0 0 0" name="root_x_arg"/> -->
      <geom class="visual" type="mesh" mesh="body" rgba="1.0 1.0 1.0 1.0"/>
      <geom type="mesh" mesh="body" group="0" />
      <inertial pos="-0.009938 0 -0.032447" mass="0.232530" diaginertia="3.444e-4 1.044e-3 7.756e-4" />
      <site name="imu_site" pos="-0.025 0 0" size="0.01" rgba="1 0 0 1"/>


      <!-- back_tire -->
      <body name="back_tire" pos="0.053157 0.0 -0.079" quat="0 0 0 1">
        <joint name="back_tire_pitch" type="hinge" pos="0 0 0" axis="0 -1 0" limited="false" damping="0.00001" armature="1.45e-5"/>
        <inertial pos="-0 -0.001706 -0" mass="0.01531" diaginertia="6.036819e-6 1.130432e-5 6.03682e-6" />
        <geom class="visual" type="mesh" mesh="back_tire"/>
        <geom type="mesh" mesh="back_tire" group="0" friction="0.9 0.05 0.01"/>
        <geom class="visual" type="box" size="0.005 0.005 0.002" pos="0.02 -0.002 0" rgba="1 0 0 1"/>
      </body>

      <!-- front_tire_holder -->
      <body name="front_tire_holder" pos="-0.077 0.0 -0.034">
        <joint name="front_tire_holder" type="hinge" pos="0 0 0" axis="0 0 1" 
            range="-3.14159 3.14159" limited="true" damping="0.00001" />
        <inertial pos="0 0 -0.013803" mass="0.007261" diaginertia="2.248766e-6 1.986811e-6 9.96848e-7" />
        <geom class="visual" type="mesh" mesh="front_tire_holder" rgba="1.0 1.0 1.0 1.0" />
        <geom type="mesh" mesh="front_tire_holder" group="0" />

        <!-- front_tire -->
        <body name="front_tire" pos="0.0 0.0 -0.042">
          <joint name="front_tire_pitch" type="hinge" pos="0 0 0" axis="0 1 0" limited="false" damping="0.00001" />
          <inertial pos="-0 -0 -0" mass="0.045011" diaginertia="1.3522043e-5 2.6042188e-5 1.3522044e-5" />
          <geom class="visual" type="mesh" mesh="front_tire" rgba="1.0 1.0 1.0 1.0"/>
          <geom type="mesh" mesh="front_tire" group="0"  friction="0.9 0.05 0.01"/>
          <geom class="visual" type="box" size="0.005 0.005 0.002" pos="0.02 -0.002 0" rgba="1 0 0 1"/>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <position name="fork_controler" joint="front_tire_holder" gear="1" 
          kp="100" kv="1" forcerange="-0.065 0.065" forcelimited="true"/>
    <motor name="back_tire_motor" joint="back_tire_pitch" gear="1"/>
    <!-- <general name="back_tire_motor" joint="back_tire_pitch" 
                dyntype="filter" dynprm="0.0055"
                gaintype="fixed" gainprm="1" 
                biastype="affine" biasprm="0 0 -0.0"/> -->
  </actuator>

  <contact>
    <exclude body1="body_obj" body2="back_tire" />
    <exclude body1="body_obj" body2="front_tire" />
    <exclude body1="body_obj" body2="front_tire_holder" />
    <exclude body1="front_tire_holder" body2="front_tire" />
  </contact>

  <sensor>
    <accelerometer name="body_accel" site="imu_site"/>
    <gyro name="body_gyro" site="imu_site" />  
  </sensor>
</mujoco>
