<mujoco model="meshes_mjcf">
  <compiler angle="radian" meshdir="assets" autolimits="true" />

  <option timestep="0.001" iterations="30" cone="elliptic" impratio="100" />

  <default>
    <!-- textset -->
    <!-- <joint damping="0.1" armature="0.01" frictionloss="0.005"/> -->
    <!-- <position inheritrange="1" timeconst="0.01"/> -->
    <!-- <geom friction="0.4" margin="0.001" condim="3"/> -->
    <!-- text�[text�Fgroup=0 -->
    <default class="collision">
      <geom group="0"/>
    </default>
    <!-- text�Fgroup=1(text) -->
    <default class="visual">
      <geom contype="0" conaffinity="0" group="1"/>
    </default>
  </default>

  <asset>
    <material name="metal" rgba=".9 .95 .95 1" />
    <material name="black" rgba="0 0 0 1" />
    <material name="white" rgba="1 1 1 1" />
    <material name="gray" rgba="0.671705 0.692426 0.774270 1" />

    <mesh name="back-tire" file="back-tire.obj" />
    <mesh name="body" file="body.obj" />
    <mesh name="front-tire" file="front-tire.obj" />
  </asset>

  <worldbody>
    <body name="body_obj" pos="0 0 0.08">
      <freejoint />
      <geom class="visual" type="mesh" mesh="body" rgba="1.0 1.0 1.0 1.0"/>
      <geom type="mesh" mesh="body" group="0" />
      <inertial pos="0.042941 0.000014 -0.02614" mass="0.2438" diaginertia="2.999e-4 4.445e-4 3.941e-4" />
      <site name="imu_site" pos="0.01 0 0.004"/>
      
      <!-- back-tire -->
      <body name="back-tire" pos="0.065528 0.0 -0.045">
        <joint name="back_tire_pitch" type="hinge" pos="0 0 0" axis="0 1 0" limited="false" damping="0.00001" />
        <inertial pos="0.0 0.0 0.0" mass="0.021" diaginertia="6.595356e-6 1.2702637e-5 6.595358e-6" />
        <geom class="visual" type="mesh" mesh="back-tire"/>
        <geom type="mesh" mesh="back-tire" group="0"  friction="0.9 0.05 0.001" />
      </body>

      <!-- front-tire -->
      <body name="front-tire" pos="-0.035 0.0 -0.045" quat="0.866025291583566 0 0 -0.500000194337561">
        <joint name="front_tire_pitch" type="hinge" pos="0 0 0" axis="0 1 0" limited="false" damping="0.00001" />
        <inertial pos="0.0 0.0 0.0" mass="0.026" diaginertia="7.810778e-6 1.5042828e-5 7.810779e-6" />
        <geom class="visual" type="mesh" mesh="front-tire" rgba="1.0 1.0 1.0 1.0"/>
        <geom type="mesh" mesh="front-tire" group="0" friction="0.9 0.05 0.001"/>
      </body>
    </body>
  </worldbody>

  <actuator>
    <general name="back_tire_actuator" joint="back_tire_pitch" 
            gear="1" forcelimited="true" forcerange="-0.042 0.042"
            dyntype="filter" dynprm="0.0055"
            gaintype="fixed" biastype="affine" biasprm="0 0 -0.000333"/>
  </actuator>

  <contact>
    <exclude body1="body_obj" body2="back-tire" />
    <exclude body1="body_obj" body2="front-tire" />
  </contact>

  <sensor>
    <accelerometer name="body_accel" site="imu_site" noise="0.0"/>
    <gyro name="body_gyro" site="imu_site" noise="0.0"/>
  </sensor>
</mujoco>
